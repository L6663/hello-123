{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/character-state.schema.json",
  "title": "Stage 4 temporal character state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "state_id", "character_id", "state_type", "state_value",
    "start_chapter_id", "end_chapter_id", "start_position", "end_position",
    "tier", "assertion_ids", "evidence_anchor_ids", "confidence", "limitations",
    "attribution", "status"
  ],
  "properties": {
    "schema_version": {"const": "tkr-character-state-v1"},
    "state_id": {"type": "string", "minLength": 1},
    "character_id": {"type": "string", "pattern": "^fch_[0-9a-f]{32}$"},
    "state_type": {"type": "string", "minLength": 1},
    "state_value": {"type": "string", "minLength": 1},
    "start_chapter_id": {"type": "string", "pattern": "^cch_[0-9a-f]{32}$"},
    "end_chapter_id": {"type": "string", "pattern": "^cch_[0-9a-f]{32}$"},
    "start_position": {"type": "integer", "minimum": 0},
    "end_position": {"type": "integer", "minimum": 0},
    "tier": {"enum": ["A", "B"]},
    "assertion_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "evidence_anchor_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "attribution": {"enum": ["source_explicit", "source_direct_event", "source_direct_dialogue", "cross_evidence_synthesis"]},
    "status": {"enum": ["active", "contested", "review_only", "superseded"]}
  }
}
