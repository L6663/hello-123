{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/notion-project-report.schema.json",
  "title": "Stage 6 Notion Project report",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "status", "notion_engine_version", "output_directory", "page_count", "relation_count", "review_count", "blocking_review_count", "database_counts", "action_counts", "projection_valid", "chapter_project_logical_sha256", "literary_project_ids", "evidence_project_logical_sha256s", "event_project_logical_sha256", "character_project_logical_sha256", "reasoning_project_logical_sha256", "ledger_sha256", "logical_sha256", "database_sha256", "project_acceptance_performed", "may_accept_project", "may_release", "may_freeze"],
  "properties": {
    "schema_version": {"const": "tkr-notion-project-report-v1"},
    "status": {"enum": ["completed", "review_required"]},
    "notion_engine_version": {"type": "string", "minLength": 1},
    "output_directory": {"const": "."},
    "page_count": {"type": "integer", "minimum": 0},
    "relation_count": {"type": "integer", "minimum": 0},
    "review_count": {"type": "integer", "minimum": 0},
    "blocking_review_count": {"type": "integer", "minimum": 0},
    "database_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "action_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "projection_valid": {"type": "boolean"},
    "chapter_project_logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "literary_project_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "evidence_project_logical_sha256s": {"type": "array", "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "uniqueItems": true},
    "event_project_logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "character_project_logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reasoning_project_logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "ledger_sha256": {"type": "string", "pattern": "^$|^[0-9a-f]{64}$"},
    "logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "database_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "project_acceptance_performed": {"const": false},
    "may_accept_project": {"const": false},
    "may_release": {"const": false},
    "may_freeze": {"const": false}
  }
}
