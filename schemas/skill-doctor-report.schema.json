{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://text-knowledge-reader.invalid/schemas/skill-doctor-report.schema.json",
  "title": "Text Knowledge Reader Skill Doctor Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "audit_version", "status", "passed", "python_version", "sqlite_version",
    "check_count", "checks", "project_acceptance_performed", "may_accept_project",
    "release_candidate", "may_freeze"
  ],
  "properties": {
    "schema_version": {"const": "tkr-skill-doctor-v1"},
    "audit_version": {"const": "5.9.0-stage5"},
    "status": {"enum": ["passed", "failed"]},
    "passed": {"type": "boolean"},
    "python_version": {"type": "string", "minLength": 1},
    "sqlite_version": {"type": "string", "minLength": 1},
    "check_count": {"type": "integer", "minimum": 0},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "status": {"enum": ["passed", "failed"]},
          "detail": {"type": "string"}
        }
      }
    },
    "project_acceptance_performed": {"const": false},
    "may_accept_project": {"const": false},
    "release_candidate": {"const": false},
    "may_freeze": {"const": false}
  }
}
