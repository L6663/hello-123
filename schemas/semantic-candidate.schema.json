{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/semantic-candidate.schema.json",
  "title": "Text Knowledge Reader Semantic Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","candidate_id","claim_type","subject","object","value","unit","polarity","discourse_status","factual_status","attributor","source_id","source_sha256","unit_id","extraction_rule","confidence","evidence_start","evidence_end","evidence_start_line","evidence_end_line","evidence_sha256","evidence_text","trigger_start","trigger_end","validation_status","validation_result_id","validation_reason_codes","may_index","requires_review"],
  "properties": {
    "schema_version": {"const": "tkr-semantic-candidate-v1"},
    "candidate_id": {"type": "string", "pattern": "^sem_[0-9a-f]{32}$"},
    "claim_type": {"enum": ["alias","defeats","located_in","permission","count","date"]},
    "subject": {"type": "string"},
    "object": {"type": "string"},
    "value": {"type": ["string","number","null"]},
    "unit": {"type": "string"},
    "polarity": {"type": "boolean"},
    "discourse_status": {"enum": ["assertion","belief","suspicion","rumor","accusation","hypothetical","question","future_intent"]},
    "factual_status": {"enum": ["asserted_fact","negated_fact","belief","suspicion","rumor","accusation","hypothetical","question","future_intent"]},
    "attributor": {"type": "string"},
    "source_id": {"type": "string", "minLength": 1},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "unit_id": {"type": "string", "minLength": 1},
    "extraction_rule": {"type": "string", "minLength": 1},
    "confidence": {"enum": ["low","medium","high"]},
    "evidence_start": {"type": "integer", "minimum": 0},
    "evidence_end": {"type": "integer", "minimum": 1},
    "evidence_start_line": {"type": "integer", "minimum": 1},
    "evidence_end_line": {"type": "integer", "minimum": 1},
    "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence_text": {"type": "string"},
    "trigger_start": {"type": "integer", "minimum": 0},
    "trigger_end": {"type": "integer", "minimum": 1},
    "validation_status": {"enum": ["accepted","review","rejected","not_validated_nonassertive"]},
    "validation_result_id": {"type": ["string","null"]},
    "validation_reason_codes": {"type": "array", "items": {"type": "string"}},
    "may_index": {"type": "boolean"},
    "requires_review": {"type": "boolean"}
  }
}
