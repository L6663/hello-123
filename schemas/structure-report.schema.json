{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://text-knowledge-reader.local/schemas/structure-report.schema.json",
  "title": "Text Knowledge Reader Structure Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "detector_version", "source_id", "source_sha256", "size_bytes",
    "selected_encoding", "offset_basis", "scan_status", "scanned_character_count",
    "scanned_line_count", "heading_candidate_count", "accepted_heading_count",
    "unit_count", "finding_count", "unit_type_counts", "finding_rule_counts",
    "coverage_character_count", "coverage_ratio", "gap_count", "overlap_count",
    "recommended_action", "blockers", "warnings", "policy", "headings", "units",
    "findings", "project_acceptance_performed", "may_accept_project", "may_freeze"
  ],
  "properties": {
    "schema_version": {"const": "tkr-structure-report-v1"},
    "detector_version": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "size_bytes": {"type": "integer", "minimum": 0},
    "selected_encoding": {"type": ["string", "null"]},
    "offset_basis": {"const": "decoded_text_without_external_bom"},
    "scan_status": {"type": "string", "enum": ["completed", "blocked"]},
    "scanned_character_count": {"type": "integer", "minimum": 0},
    "scanned_line_count": {"type": "integer", "minimum": 0},
    "heading_candidate_count": {"type": "integer", "minimum": 0},
    "accepted_heading_count": {"type": "integer", "minimum": 0},
    "unit_count": {"type": "integer", "minimum": 0},
    "finding_count": {"type": "integer", "minimum": 0},
    "unit_type_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "finding_rule_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "coverage_character_count": {"type": "integer", "minimum": 0},
    "coverage_ratio": {"type": "number", "minimum": 0, "maximum": 1},
    "gap_count": {"type": "integer", "minimum": 0},
    "overlap_count": {"type": "integer", "minimum": 0},
    "recommended_action": {"type": "string", "minLength": 1},
    "blockers": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "warnings": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "policy": {"type": "object"},
    "headings": {"type": "array", "items": {"type": "object"}},
    "units": {"type": "array", "items": {"type": "object"}},
    "findings": {"type": "array", "items": {"type": "object"}},
    "project_acceptance_performed": {"const": false},
    "may_accept_project": {"const": false},
    "may_freeze": {"const": false}
  }
}
