{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/knowledge-project-report.schema.json",
  "title": "Text Knowledge Reader Stage 4 Knowledge Project Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "system_version", "project_id", "status", "index_mode",
    "source_id", "source_filename", "source_suffix", "raw_source_sha256",
    "normalized_source_sha256", "selected_encoding", "unit_count",
    "semantic_candidate_count", "accepted_claim_count", "entity_count", "fact_count",
    "conflict_count", "ambiguity_group_count", "anomaly_finding_count",
    "structure_finding_count", "semantic_finding_count", "index_logical_sha256",
    "database_sha256", "recommended_action", "warnings", "policy", "may_query_typed",
    "may_answer_open_queries", "project_acceptance_performed", "may_accept_project",
    "release_candidate", "may_freeze"
  ],
  "properties": {
    "schema_version": {"const": "tkr-knowledge-project-v1"},
    "system_version": {"const": "5.9.0-stage6-r2"},
    "project_id": {"type": "string", "pattern": "^kpr_[0-9a-f]{32}$"},
    "status": {"const": "completed"},
    "index_mode": {"enum": ["review", "canonical"]},
    "source_id": {"type": "string", "minLength": 1},
    "source_filename": {"type": "string", "minLength": 1},
    "source_suffix": {"type": "string"},
    "raw_source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "normalized_source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "selected_encoding": {"type": "string", "minLength": 1},
    "unit_count": {"type": "integer", "minimum": 1},
    "semantic_candidate_count": {"type": "integer", "minimum": 1},
    "accepted_claim_count": {"type": "integer", "minimum": 1},
    "entity_count": {"type": "integer", "minimum": 0},
    "fact_count": {"type": "integer", "minimum": 1},
    "conflict_count": {"type": "integer", "minimum": 0},
    "ambiguity_group_count": {"type": "integer", "minimum": 0},
    "anomaly_finding_count": {"type": "integer", "minimum": 0},
    "structure_finding_count": {"type": "integer", "minimum": 0},
    "semantic_finding_count": {"type": "integer", "minimum": 0},
    "index_logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "database_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "recommended_action": {"const": "typed_knowledge_project_ready"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "policy": {"type": "object"},
    "may_query_typed": {"const": true},
    "may_answer_open_queries": {"const": false},
    "project_acceptance_performed": {"const": false},
    "may_accept_project": {"const": false},
    "release_candidate": {"const": false},
    "may_freeze": {"const": false}
  }
}
