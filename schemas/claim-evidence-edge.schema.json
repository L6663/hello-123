{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/claim-evidence-edge.schema.json",
  "title": "Text Knowledge Reader Claim-Evidence Edge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "edge_id",
    "assertion_id",
    "evidence_id",
    "relation",
    "evidence_source_status",
    "ordinal",
    "confidence",
    "review_status"
  ],
  "properties": {
    "schema_version": {"const": "tkr-claim-evidence-edge-v1"},
    "edge_id": {"type": "string", "pattern": "^cee_[0-9a-f]{32}$"},
    "assertion_id": {"type": "string", "minLength": 1},
    "evidence_id": {"type": "string", "minLength": 1},
    "relation": {"enum": ["support", "contradict", "context"]},
    "evidence_source_status": {
      "enum": ["clean", "contaminated", "non_body", "needs_review"]
    },
    "ordinal": {"type": "integer", "minimum": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "review_status": {"enum": ["accepted_edge", "review_edge"]}
  },
  "allOf": [
    {
      "if": {"properties": {"relation": {"const": "support"}}},
      "then": {"properties": {"review_status": {"const": "accepted_edge"}}}
    }
  ]
}
