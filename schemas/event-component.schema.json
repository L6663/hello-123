{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/event-component.schema.json",
  "title": "Stage 3 event component",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "component_id", "event_id", "component_type", "tier",
    "statement", "assertion_ids", "evidence_anchor_ids", "supporting_component_ids",
    "confidence", "limitations", "attribution", "status"
  ],
  "properties": {
    "schema_version": {"const": "tkr-event-component-v1"},
    "component_id": {"type": "string", "pattern": "^evc_[0-9a-f]{32}$"},
    "event_id": {"type": "string", "pattern": "^cev_[0-9a-f]{32}$"},
    "component_type": {"enum": ["cause", "process", "outcome", "consequence", "foreshadowing", "recovery"]},
    "tier": {"enum": ["A", "B", "C"]},
    "statement": {"type": "string", "minLength": 1},
    "assertion_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "evidence_anchor_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "supporting_component_ids": {"type": "array", "items": {"type": "string", "pattern": "^evc_[0-9a-f]{32}$"}, "uniqueItems": true},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "attribution": {"enum": ["source_explicit", "source_direct_event", "source_direct_dialogue", "cross_evidence_synthesis", "model_interpretation"]},
    "status": {"enum": ["active", "contested", "superseded", "review_only"]}
  }
}
