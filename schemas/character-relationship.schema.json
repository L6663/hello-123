{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/character-relationship.schema.json",
  "title": "Stage 4 temporal character relationship",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "relationship_id", "subject_character_id",
    "object_character_id", "relation_type", "tier", "start_chapter_id",
    "end_chapter_id", "start_position", "end_position", "change_event_ids",
    "assertion_ids", "evidence_anchor_ids", "supporting_relationship_ids",
    "confidence", "limitations", "attribution", "status"
  ],
  "properties": {
    "schema_version": {"const": "tkr-character-relationship-v1"},
    "relationship_id": {"type": "string", "minLength": 1},
    "subject_character_id": {"type": "string", "pattern": "^fch_[0-9a-f]{32}$"},
    "object_character_id": {"type": "string", "pattern": "^fch_[0-9a-f]{32}$"},
    "relation_type": {"type": "string", "minLength": 1},
    "tier": {"enum": ["A", "B", "C"]},
    "start_chapter_id": {"type": "string", "pattern": "^cch_[0-9a-f]{32}$"},
    "end_chapter_id": {"type": "string", "pattern": "^cch_[0-9a-f]{32}$"},
    "start_position": {"type": "integer", "minimum": 0},
    "end_position": {"type": "integer", "minimum": 0},
    "change_event_ids": {"type": "array", "items": {"type": "string", "pattern": "^cev_[0-9a-f]{32}$"}, "uniqueItems": true},
    "assertion_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "evidence_anchor_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "supporting_relationship_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "attribution": {"enum": ["source_explicit", "source_direct_event", "source_direct_dialogue", "cross_evidence_synthesis", "model_interpretation"]},
    "status": {"enum": ["active", "contested", "review_only", "superseded"]}
  }
}
