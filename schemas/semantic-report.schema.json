{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/semantic-report.schema.json",
  "title": "Text Knowledge Reader Semantic Extraction Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","extractor_version","source_id","source_sha256","size_bytes","selected_encoding","offset_basis","scan_status","scanned_character_count","scanned_unit_count","candidate_count","accepted_candidate_count","review_candidate_count","rejected_candidate_count","nonassertive_candidate_count","model_task_count","finding_count","claim_type_counts","discourse_status_counts","validation_status_counts","recommended_action","blockers","warnings","policy","candidates","findings","model_tasks","accepted_records","normalization","project_acceptance_performed","may_accept_project","may_freeze"],
  "properties": {
    "schema_version": {"const": "tkr-semantic-report-v1"},
    "extractor_version": {"const": "5.9.0-stage3"},
    "source_id": {"type": "string", "minLength": 1},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "size_bytes": {"type": "integer", "minimum": 0},
    "selected_encoding": {"type": ["string","null"]},
    "offset_basis": {"const": "decoded_text_without_external_bom"},
    "scan_status": {"enum": ["completed","blocked"]},
    "scanned_character_count": {"type": "integer", "minimum": 0},
    "scanned_unit_count": {"type": "integer", "minimum": 0},
    "candidate_count": {"type": "integer", "minimum": 0},
    "accepted_candidate_count": {"type": "integer", "minimum": 0},
    "review_candidate_count": {"type": "integer", "minimum": 0},
    "rejected_candidate_count": {"type": "integer", "minimum": 0},
    "nonassertive_candidate_count": {"type": "integer", "minimum": 0},
    "model_task_count": {"type": "integer", "minimum": 0},
    "finding_count": {"type": "integer", "minimum": 0},
    "claim_type_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "discourse_status_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "validation_status_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "recommended_action": {"type": "string"},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "policy": {"type": "object"},
    "candidates": {"type": "array", "items": {"$ref": "semantic-candidate.schema.json"}},
    "findings": {"type": "array", "items": {"$ref": "semantic-finding.schema.json"}},
    "model_tasks": {"type": "array", "items": {"$ref": "model-extraction-task.schema.json"}},
    "accepted_records": {"type": "array", "items": {"$ref": "accepted-claim-record.schema.json"}},
    "normalization": {"type": "object"},
    "project_acceptance_performed": {"const": false},
    "may_accept_project": {"const": false},
    "may_freeze": {"const": false}
  }
}
