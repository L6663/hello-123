{
  "$id": "https://text-knowledge-reader.local/schemas/final-acceptance-verification.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "candidate_id": {"pattern": "^final_acceptance_candidate_[0-9a-f]{24}$", "type": "string"},
    "may_accept_project": {"type": "boolean"},
    "may_freeze": {"const": false},
    "may_release": {"const": false},
    "project_acceptance_performed": {"type": "boolean"},
    "reason_codes": {"items": {"minLength": 1, "type": "string"}, "minItems": 1, "type": "array", "uniqueItems": true},
    "release_candidate": {"type": "boolean"},
    "schema_version": {"const": "tkr-final-acceptance-verification-v1"},
    "seal_id": {"type": "string"},
    "status": {"const": "verified"},
    "valid": {"const": true}
  },
  "required": [
    "schema_version", "status", "valid", "candidate_id", "seal_id",
    "reason_codes", "project_acceptance_performed", "may_accept_project",
    "release_candidate", "may_release", "may_freeze"
  ],
  "title": "Final Product Acceptance Verification",
  "type": "object"
}
