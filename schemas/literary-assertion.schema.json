{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/literary-assertion.schema.json",
  "title": "Tiered literary knowledge assertion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "assertion_id", "tier", "assertion_kind",
    "subject_entity_id", "subject_text", "predicate", "object_entity_id",
    "object_text", "value", "polarity", "temporal_start_chapter_id",
    "temporal_end_chapter_id", "confidence", "evidence_anchor_ids",
    "supporting_assertion_ids", "limitations", "attribution", "status", "revision"
  ],
  "properties": {
    "schema_version": {"const": "tkr-literary-assertion-v1"},
    "assertion_id": {"type": "string", "pattern": "^las_[0-9a-f]{32}$"},
    "tier": {"enum": ["A", "B", "C"]},
    "assertion_kind": {
      "enum": ["fact", "synthesis", "interpretation", "relationship", "event_component", "ability_property", "place_property", "identity"]
    },
    "subject_entity_id": {"type": ["string", "null"]},
    "subject_text": {"type": "string", "minLength": 1},
    "predicate": {"type": "string", "minLength": 1},
    "object_entity_id": {"type": ["string", "null"]},
    "object_text": {"type": "string"},
    "value": {},
    "polarity": {"type": "boolean"},
    "temporal_start_chapter_id": {"type": ["string", "null"]},
    "temporal_end_chapter_id": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_anchor_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^lea_[0-9a-f]{32}$"},
      "uniqueItems": true
    },
    "supporting_assertion_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^las_[0-9a-f]{32}$"},
      "uniqueItems": true
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "attribution": {
      "enum": ["source_explicit", "source_direct_event", "source_direct_dialogue", "cross_evidence_synthesis", "model_interpretation"]
    },
    "status": {"enum": ["active", "superseded", "contested", "retracted", "needs_review"]},
    "revision": {"type": "integer", "minimum": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"tier": {"const": "A"}}},
      "then": {
        "properties": {
          "evidence_anchor_ids": {"minItems": 1},
          "attribution": {"enum": ["source_explicit", "source_direct_event", "source_direct_dialogue"]}
        }
      }
    },
    {
      "if": {"properties": {"tier": {"const": "B"}}},
      "then": {
        "properties": {
          "assertion_kind": {"not": {"const": "interpretation"}},
          "attribution": {"const": "cross_evidence_synthesis"}
        }
      }
    },
    {
      "if": {"properties": {"tier": {"const": "C"}}},
      "then": {
        "properties": {
          "assertion_kind": {"const": "interpretation"},
          "attribution": {"const": "model_interpretation"}
        }
      }
    }
  ]
}
