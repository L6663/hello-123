{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/knowledge-project-verification.schema.json",
  "title": "Text Knowledge Reader Stage 4 Project Verification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "system_version", "project_id", "status", "valid",
    "checked_file_count", "reason_codes", "source_id", "raw_source_sha256",
    "normalized_source_sha256", "index_logical_sha256", "may_query_typed",
    "project_acceptance_performed", "may_accept_project", "may_freeze"
  ],
  "properties": {
    "schema_version": {"const": "tkr-knowledge-verification-v1"},
    "system_version": {"const": "5.9.0-stage6-r1"},
    "project_id": {"type": "string"},
    "status": {"enum": ["verified", "rejected"]},
    "valid": {"type": "boolean"},
    "checked_file_count": {"type": "integer", "minimum": 0},
    "reason_codes": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "source_id": {"type": "string"},
    "raw_source_sha256": {"type": "string"},
    "normalized_source_sha256": {"type": "string"},
    "index_logical_sha256": {"type": "string"},
    "may_query_typed": {"type": "boolean"},
    "project_acceptance_performed": {"const": false},
    "may_accept_project": {"const": false},
    "may_freeze": {"const": false}
  }
}
