{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/character-project-report.schema.json",
  "title": "Stage 4 Character Project report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version", "status", "character_engine_version",
    "character_sqlite_schema_version", "chapter_project_logical_sha256",
    "literary_project_ids", "literary_project_logical_sha256",
    "event_project_logical_sha256", "event_graph_valid", "annotation_sha256",
    "character_count", "core_count", "important_count", "placeholder_count",
    "attribute_count", "state_count", "relationship_count", "event_link_count",
    "finding_count", "unsupported_reference_count", "temporal_conflict_count",
    "graph_valid", "logical_sha256", "database_sha256",
    "project_acceptance_performed", "may_accept_project", "may_release", "may_freeze"
  ],
  "properties": {
    "schema_version": {"const": "tkr-character-project-report-v1"},
    "status": {"enum": ["completed", "review_required"]},
    "character_engine_version": {"const": "tkr-character-engine-v1"},
    "character_sqlite_schema_version": {"const": "tkr-character-sqlite-v1"},
    "chapter_project_logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "literary_project_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "literary_project_logical_sha256": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "event_project_logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "event_graph_valid": {"type": "boolean"},
    "annotation_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "character_count": {"type": "integer", "minimum": 0},
    "core_count": {"type": "integer", "minimum": 0},
    "important_count": {"type": "integer", "minimum": 0},
    "placeholder_count": {"type": "integer", "minimum": 0},
    "attribute_count": {"type": "integer", "minimum": 0},
    "state_count": {"type": "integer", "minimum": 0},
    "relationship_count": {"type": "integer", "minimum": 0},
    "event_link_count": {"type": "integer", "minimum": 0},
    "finding_count": {"type": "integer", "minimum": 0},
    "unsupported_reference_count": {"type": "integer", "minimum": 0},
    "temporal_conflict_count": {"type": "integer", "minimum": 0},
    "graph_valid": {"type": "boolean"},
    "logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "database_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "project_acceptance_performed": {"const": false},
    "may_accept_project": {"const": false},
    "may_release": {"const": false},
    "may_freeze": {"const": false}
  }
}
