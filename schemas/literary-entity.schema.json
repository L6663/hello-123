{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/literary-entity.schema.json",
  "title": "Literary entity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "entity_id", "canonical_name", "aliases", "entity_type",
    "first_chapter_id", "last_chapter_id", "source_ids", "mention_anchor_ids",
    "identity_basis_assertion_ids", "review_status"
  ],
  "properties": {
    "schema_version": {"const": "tkr-literary-entity-v1"},
    "entity_id": {"type": "string", "minLength": 1},
    "canonical_name": {"type": "string", "minLength": 1},
    "aliases": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "entity_type": {"enum": ["person", "faction", "ability", "place", "item", "event", "concept", "species", "unknown"]},
    "first_chapter_id": {"type": ["string", "null"]},
    "last_chapter_id": {"type": ["string", "null"]},
    "source_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "mention_anchor_ids": {"type": "array", "items": {"type": "string", "pattern": "^lea_[0-9a-f]{32}$"}, "uniqueItems": true},
    "identity_basis_assertion_ids": {"type": "array", "items": {"type": "string", "pattern": "^las_[0-9a-f]{32}$"}, "uniqueItems": true},
    "review_status": {"type": "string", "minLength": 1}
  }
}
