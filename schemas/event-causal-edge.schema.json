{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/event-causal-edge.schema.json",
  "title": "Stage 3 event causal edge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "edge_id", "source_event_id", "relation_type",
    "target_event_id", "tier", "assertion_ids", "evidence_anchor_ids",
    "supporting_component_ids", "source_position", "target_position",
    "temporal_direction", "confidence", "limitations", "attribution", "status"
  ],
  "properties": {
    "schema_version": {"const": "tkr-event-causal-edge-v1"},
    "edge_id": {"type": "string", "pattern": "^ece_[0-9a-f]{32}$"},
    "source_event_id": {"type": "string", "pattern": "^cev_[0-9a-f]{32}$"},
    "relation_type": {"enum": ["triggers", "enables", "escalates", "prevents", "reveals", "undermines", "resolves", "foreshadows", "recovers"]},
    "target_event_id": {"type": "string", "pattern": "^cev_[0-9a-f]{32}$"},
    "tier": {"enum": ["A", "B", "C"]},
    "assertion_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "evidence_anchor_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "supporting_component_ids": {"type": "array", "items": {"type": "string", "pattern": "^evc_[0-9a-f]{32}$"}, "uniqueItems": true},
    "source_position": {"type": "integer", "minimum": 0},
    "target_position": {"type": "integer", "minimum": 0},
    "temporal_direction": {"enum": ["forward", "backward_reference"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "attribution": {"enum": ["source_explicit", "source_direct_event", "source_direct_dialogue", "cross_evidence_synthesis", "model_interpretation"]},
    "status": {"enum": ["active", "contested", "review_only", "superseded"]}
  }
}
