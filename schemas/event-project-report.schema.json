{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/event-project-report.schema.json",
  "title": "Stage 3 Event Project report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version", "status", "event_engine_version", "event_sqlite_schema_version",
    "chapter_project_logical_sha256", "literary_project_ids",
    "literary_project_logical_sha256", "annotation_sha256", "event_count",
    "component_count", "edge_count", "active_event_count", "active_edge_count",
    "tier_a_component_count", "tier_b_component_count", "tier_c_component_count",
    "finding_count", "cycle_count", "unsupported_reference_count",
    "temporal_violation_count", "graph_valid", "logical_sha256", "database_sha256",
    "project_acceptance_performed", "may_accept_project", "may_release", "may_freeze"
  ],
  "properties": {
    "schema_version": {"const": "tkr-event-project-report-v1"},
    "status": {"enum": ["completed", "review_required"]},
    "event_engine_version": {"const": "tkr-event-engine-v1"},
    "event_sqlite_schema_version": {"const": "tkr-event-sqlite-v1"},
    "chapter_project_logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "literary_project_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "literary_project_logical_sha256": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "annotation_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "event_count": {"type": "integer", "minimum": 0},
    "component_count": {"type": "integer", "minimum": 0},
    "edge_count": {"type": "integer", "minimum": 0},
    "active_event_count": {"type": "integer", "minimum": 0},
    "active_edge_count": {"type": "integer", "minimum": 0},
    "tier_a_component_count": {"type": "integer", "minimum": 0},
    "tier_b_component_count": {"type": "integer", "minimum": 0},
    "tier_c_component_count": {"type": "integer", "minimum": 0},
    "finding_count": {"type": "integer", "minimum": 0},
    "cycle_count": {"type": "integer", "minimum": 0},
    "unsupported_reference_count": {"type": "integer", "minimum": 0},
    "temporal_violation_count": {"type": "integer", "minimum": 0},
    "graph_valid": {"type": "boolean"},
    "logical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "database_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "project_acceptance_performed": {"const": false},
    "may_accept_project": {"const": false},
    "may_release": {"const": false},
    "may_freeze": {"const": false}
  }
}
