{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tkr/canonical-chapter.schema.json",
  "title": "Stage 2 canonical chapter record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "chapter_id", "source_binding_id", "project_id",
    "source_id", "source_filename", "source_sha256", "source_input_order",
    "local_physical_order", "global_physical_order", "unit_id",
    "parent_unit_id", "heading_id", "unit_type", "volume_ordinal",
    "volume_basis", "chapter_ordinal", "chapter_basis", "original_heading",
    "normalized_heading", "title", "heading_status", "start_char", "end_char",
    "start_line", "end_line", "heading_start_char", "heading_end_char",
    "body_start_char", "body_end_char", "content_sha256",
    "structure_confidence", "review_status", "contamination_status",
    "canonical_key"
  ],
  "properties": {
    "schema_version": {"const": "tkr-canonical-chapter-v1"},
    "chapter_id": {"type": "string", "pattern": "^cch_[0-9a-f]{32}$"},
    "source_binding_id": {"type": "string", "pattern": "^csb_[0-9a-f]{32}$"},
    "project_id": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "source_filename": {"type": "string", "minLength": 1},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_input_order": {"type": "integer", "minimum": 0},
    "local_physical_order": {"type": "integer", "minimum": 0},
    "global_physical_order": {"type": "integer", "minimum": 0},
    "unit_id": {"type": "string", "minLength": 1},
    "parent_unit_id": {"type": ["string", "null"]},
    "heading_id": {"type": ["string", "null"]},
    "unit_type": {"enum": ["chapter", "prologue", "epilogue", "extra_story"]},
    "volume_ordinal": {"type": ["integer", "null"], "minimum": 1},
    "volume_basis": {"enum": ["combined_heading", "parent_volume_unit", "preceding_volume_context", "unknown"]},
    "chapter_ordinal": {"type": ["integer", "null"], "minimum": 1},
    "chapter_basis": {"enum": ["explicit_heading", "special_unit", "unknown"]},
    "original_heading": {"type": "string"},
    "normalized_heading": {"type": "string"},
    "title": {"type": "string"},
    "heading_status": {"enum": ["explicit_title", "titleless_heading", "missing_heading", "detached_title_candidate"]},
    "start_char": {"type": "integer", "minimum": 0},
    "end_char": {"type": "integer", "minimum": 1},
    "start_line": {"type": "integer", "minimum": 0},
    "end_line": {"type": "integer", "minimum": 0},
    "heading_start_char": {"type": ["integer", "null"], "minimum": 0},
    "heading_end_char": {"type": ["integer", "null"], "minimum": 0},
    "body_start_char": {"type": "integer", "minimum": 0},
    "body_end_char": {"type": "integer", "minimum": 0},
    "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "structure_confidence": {"type": "string", "minLength": 1},
    "review_status": {"type": "string", "minLength": 1},
    "contamination_status": {"enum": ["clean", "contaminated", "non_body", "needs_review"]},
    "canonical_key": {"type": "string", "minLength": 1}
  }
}
