+    def test_self_consistent_manifest_cannot_hide_json_sqlite_divergence(self) -> None:
+        with TemporaryDirectory() as directory:
+            _, sidecar = self._build_base(Path(directory))
+            database = sidecar / "literary.sqlite"
+            connection = sqlite3.connect(database)
+            try:
+                assertion_identifier = connection.execute(
+                    "SELECT assertion_id FROM assertions ORDER BY assertion_id LIMIT 1"
+                ).fetchone()[0]
+                connection.execute(
+                    "DELETE FROM assertion_evidence WHERE assertion_id=?",
+                    (assertion_identifier,),
+                )
+                connection.execute(
+                    "DELETE FROM assertions WHERE assertion_id=?",
+                    (assertion_identifier,),
+                )
+                connection.commit()
+            finally:
+                connection.close()
+
+            def digest(path: Path) -> str:
+                return sha256(path.read_bytes()).hexdigest()
+
+            report_path = sidecar / "literary-report.json"
+            report = json.loads(report_path.read_text(encoding="utf-8"))
+            report["database_sha256"] = digest(database)
+            report["assertion_count"] -= 1
+            report["tier_a_count"] -= 1
+            report_path.write_text(
+                json.dumps(report, ensure_ascii=False, indent=2, sort_keys=True) + "\n",
+                encoding="utf-8",
+                newline="\n",
+            )
+
+            manifest_path = sidecar / "artifact-manifest.json"
+            manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
+            manifest["database_sha256"] = digest(database)
+            for record in manifest["files"]:
+                path = sidecar / record["path"]
+                record["size_bytes"] = path.stat().st_size
+                record["sha256"] = digest(path)
+            manifest_path.write_text(
+                json.dumps(manifest, ensure_ascii=False, indent=2, sort_keys=True) + "\n",
+                encoding="utf-8",
+                newline="\n",
+            )
+
+            verification = verify_literary_engine(sidecar)
+            self.assertFalse(verification.valid)
+            self.assertIn(
+                "LITERARY_JSON_SQLITE_IDENTIFIER_MISMATCH:assertions.jsonl",
+                verification.reason_codes,
+            )
+
     def test_tampered_sidecar_is_rejected(self) -> None:
