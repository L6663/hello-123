@dataclass(frozen=True, slots=True)
class QueryResult:
    query_parser_version: str
    index_schema_version: str
    index_logical_sha256: str
    intent: PredicateQuery
    answerability: str
    reason_codes: tuple[str, ...]
    resolved_entity_ids: tuple[str, ...]
    hits: tuple[RetrievalHit, ...]
