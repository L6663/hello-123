_PUNCT_RE = re.compile(r"[\s\u3000，。！？；：、,.!?;:\-—_()（）\[\]【】{}《》〈〉\"'“”‘’]+")
_TRAILING_QUESTION_RE = re.compile(r"(?:吗|呢|么|嘛)?[？?]*$")


class RetrievalError(ValueError):
    """Raised when an index input, database, or query packet is unsafe."""


