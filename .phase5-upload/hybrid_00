INDEX_SCHEMA_VERSION = "tkr-hybrid-index-v1"
QUERY_PARSER_VERSION = "tkr-predicate-query-v1"
_REQUIRED_ARTIFACTS = (
    "mentions.jsonl",
    "entities.jsonl",
    "facts.jsonl",
    "timeline.jsonl",
    "conflicts.jsonl",
    "ambiguity-groups.jsonl",
